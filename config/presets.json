    "default": {
      "name": "Default - Balanced",
      "description": "Balanced settings with moderate LLM usage",
      "composition": {
        "num_bars": 16,
        "tempo": 90,
        "time_signature": [4, 4],
        "key": "C"
      },
      "agents": {
        "harmonic": {
          "enabled": true,
          "surprise_rate": 0.1,
          "chord_duration": 4.0,
          "voicing": "block"
        },
        "melodic": {
          "enabled": true,
          "octave": 5,
          "motif_length": 4,
          "variation_rate": 0.5,
          "chord_tone_bias": 0.7,
          "llm_frequency": 0.3
        },
        "rhythmic": {
          "enabled": true,
          "base_tempo": 90,
          "tempo_range": [75, 110],
          "tempo_sensitivity": 0.7,
          "add_percussion": false
        },
        "textural": {
          "enabled": true,
          "dynamic_range": [0.5, 1.2],
          "pause_probability": 0.08,
          "voice_density_control": true,
          "crescendo_rate": 0.05,
          "enable_instrument_selection": true
        }
      },
      "llm": {
        "enabled": true,
